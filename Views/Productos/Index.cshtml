@model IEnumerable<KovakWeb.Models.Producto>

@{
    // Apagamos la plantilla por defecto para que no interfiera con nuestro diseño
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Stock - Kovak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background-color: #212529; color: white; padding-top: 20px; }
        .sidebar a { color: #adb5bd; text-decoration: none; padding: 12px 20px; display: block; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { color: white; background-color: #343a40; border-left: 4px solid #0d6efd; }
        .content { padding: 30px; }
        .placeholder-img { width: 50px; height: 50px; background-color: #e9ecef; border-radius: 5px; display: flex; align-items: center; justify-content: center; color: #adb5bd; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            
            <div class="col-md-2 sidebar position-fixed d-flex flex-column justify-content-between pb-4">
                <div>
                    <h4 class="text-center mb-4 fw-bold">Kovak Admin</h4>
                    <a href="/">📊 Dashboard</a>
                    <a href="/Productos" class="active">📦 Productos</a>
                    <a href="/Categorias">📁 Categorías</a>
                    <a href="/Pedidos">🛒 Pedidos</a>
                    <a href="/Configuracion">⚙️ Configuración</a>
                </div>
                
                <div class="px-2">
                    <a href="/Account/Logout" class="btn btn-sm btn-outline-danger w-100 rounded-pill py-2 border-0 fw-bold">
                        <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
                    </a>
                </div>
            </div>

            <div class="col-md-10 offset-md-2 content">
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>Gestión de Stock</h2>
                    <a asp-action="Crear" class="btn btn-primary fw-bold">+ Nuevo Producto</a>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Foto</th>
                                    <th>Nombre del Producto</th>
                                    <th>Precio</th>
                                    <th>Stock</th>
                                    <th>Estado</th>
                                    <th class="text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            No hay productos registrados. Hacé clic en "+ Nuevo Producto" para cargar el primero.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                @if (!string.IsNullOrEmpty(item.UrlImagen))
                                                {
                                                    <img src="@item.UrlImagen" width="50" height="50" style="object-fit: cover; border-radius: 5px;" alt="Producto" />
                                                }
                                                else
                                                {
                                                    <div class="placeholder-img">Foto</div>
                                                }
                                            </td>
                                            <td class="fw-bold">@item.Nombre</td>
                                            <td>$ @item.Precio.ToString("N0")</td>
                                            <td>
                                                @if (item.Stock <= 2)
                                                {
                                                    <span class="text-danger fw-bold">@item.Stock un.</span>
                                                }
                                                else
                                                {
                                                    <span>@item.Stock un.</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactivo</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-action="Editar" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary me-1">Editar</a>
                                                
                                                <form asp-action="Ocultar" asp-route-id="@item.ID" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Seguro que querés cambiar el estado de este producto?');">Ocultar</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
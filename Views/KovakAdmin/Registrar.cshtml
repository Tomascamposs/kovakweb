@{ Layout = null; }

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master Registro - Kovak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0b0f19; font-family: system-ui, -apple-system, sans-serif; color: white; height: 100vh; display: flex; align-items: center; justify-content: center; margin: 0; }
        .admin-card { width: 100%; max-width: 500px; background-color: #111827; border: 1px solid #1f2937; border-radius: 16px; padding: 35px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
        .form-control { background-color: #1f2937; border: 1px solid #4b5563; color: white; border-radius: 8px; padding: 10px 12px; }
        .form-control:focus { background-color: #1f2937; border-color: #10b981; color: white; box-shadow: none; }
        .form-control::placeholder { color: #9ca3af; }
        .btn-success { background-color: #10b981; border: none; font-weight: bold; padding: 12px; border-radius: 8px; }
        .btn-success:hover { background-color: #059669; }
    </style>
</head>
<body>

    <div class="admin-card">
        <div class="mb-4">
            <h3 class="fw-bold text-success mb-1">Kovak Engine ⚙️</h3>
            <p class="text-light small">Alta inmediata de nuevos comercios y credenciales</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small border-0 text-center text-white bg-danger bg-opacity-25 mb-3">
                ⚠️ @ViewBag.Error
            </div>
        }

        @if (ViewBag.Exito != null)
        {
            <div class="alert alert-success py-2 small border-0 text-center text-white bg-success bg-opacity-25 mb-3">
                🎉 @ViewBag.Exito
            </div>
        }

        <form action="/KovakAdmin/Registrar" method="post">
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <h5 class="text-success fw-bold mb-3" style="font-size: 1rem;">Datos de la Tienda</h5>
            
            <div class="mb-3">
                <label class="form-label small text-white fw-semibold">Nombre del Comercio</label>
                <input type="text" name="nombreNegocio" class="form-control" placeholder="Ej: Grip Catalogo" required />
            </div>

            <div class="mb-4">
                <label class="form-label small text-white fw-semibold">WhatsApp (Sin espacios ni símbolos)</label>
                <input type="text" name="whatsapp" class="form-control" placeholder="Ej: 543813334444" required />
            </div>

            <h5 class="text-success fw-bold mb-3" style="font-size: 1rem;">Credenciales de Administrador</h5>

            <div class="mb-3">
                <label class="form-label small text-white fw-semibold">Correo de Acceso</label>
                <input type="email" name="emailAdmin" class="form-control" placeholder="ejemplo@comercio.com" required />
            </div>

            <div class="mb-4">
                <label class="form-label small text-white fw-semibold">Contraseña Provisional</label>
                <input type="password" name="passwordAdmin" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-success">Dar de Alta Comercio</button>
            </div>
        </form>
    </div>

</body>
</html>
@model IEnumerable<KovakWeb.Models.Categoria>

@{ Layout = null; }

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Categorías - Kovak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background-color: #212529; color: white; padding-top: 20px; }
        .sidebar a { color: #adb5bd; text-decoration: none; padding: 12px 20px; display: block; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { color: white; background-color: #343a40; border-left: 4px solid #0d6efd; }
        .content { padding: 30px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            
            <div class="col-md-2 sidebar position-fixed">
                <h4 class="text-center mb-4 fw-bold">Kovak Admin</h4>
                <a href="/">📊 Dashboard</a>
                <a href="/Productos">📦 Productos</a>
                <a href="/Categorias" class="active">📁 Categorías</a>
                <a href="/Pedidos">🛒 Pedidos</a>
                <a href="/Configuracion">⚙️ Configuración</a>
            </div>

            <div class="col-md-10 offset-md-2 content">
                <h2 class="mb-4">Gestión de Categorías</h2>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="fw-bold mb-3">Nueva Categoría</h5>
                                <form asp-action="Crear" method="post">
                                    <div class="mb-3">
                                        <input type="text" name="Nombre" class="form-control" placeholder="Ej: Camisetas Jugador" required />
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100 fw-bold">Agregar</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-0">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">ID</th>
                                            <th>Nombre</th>
                                            <th class="text-end pe-4">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Where(c => c.Activo))
                                        {
                                            <tr>
                                                <td class="ps-4 text-muted">#@item.ID</td>
                                                <td class="fw-bold">@item.Nombre</td>
                                                <td class="text-end pe-4">
                                                    <form asp-action="Eliminar" method="post" class="d-inline">
                                                        <input type="hidden" name="id" value="@item.ID" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Borrar categoría?');">Borrar</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                        @if (!Model.Any(c => c.Activo))
                                        {
                                            <tr><td colspan="3" class="text-center py-4 text-muted">No hay categorías cargadas.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kovak SaaS Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0b0f19; font-family: system-ui, sans-serif; color: white; padding: 40px 20px; }
        .dashboard-card { background-color: #111827; border: 1px solid #1f2937; border-radius: 16px; padding: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
        .table { color: white; border-color: #374151; }
        .table th { background-color: #1f2937; color: #10b981; border-bottom: 2px solid #374151; }
        .table td { background-color: #111827; vertical-align: middle; border-bottom: 1px solid #1f2937; }
        .btn-success { background-color: #10b981; border: none; font-weight: 600; }
        .btn-success:hover { background-color: #059669; }
        .btn-outline-warning { border-color: #f59e0b; color: #f59e0b; }
        .btn-outline-warning:hover { background-color: #f59e0b; color: black; }
        .btn-outline-danger { border-color: #ef4444; color: #ef4444; }
        .btn-outline-danger:hover { background-color: #ef4444; color: white; }
        .edit-row { background-color: #1f2937 !important; display: none; }
        .form-control-sm { background-color: #1f2937; border: 1px solid #4b5563; color: white; }
        .form-control-sm:focus { background-color: #1f2937; color: white; border-color: #10b981; box-shadow: none; }
        .badge-activo { background-color: rgba(16, 185, 129, 0.2); color: #10b981; }
        .badge-inactivo { background-color: rgba(239, 68, 68, 0.2); color: #ef4444; }
    </style>
</head>
<body>

    <div class="container dashboard-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-success mb-1">Kovak Dashboard ⚙️</h2>
                <p class="text-muted small mb-0">Administración general de catálogos, stock y estados de la plataforma</p>
            </div>
            <a href="/KovakAdmin/Registrar?token=@ViewBag.Token" class="btn btn-success px-4 py-2">+ Crear Nuevo Catálogo</a>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Comercio / URL</th>
                        <th>WhatsApp</th>
                        <th>Correo / Clave</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Productos</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Negocios)
                    {
                        var rowId = "edit-" + item.Negocio.ID;
                        bool esActivo = item.Negocio.Activo; 

                        <tr>
                            <td class="text-muted fw-bold">@item.Negocio.ID</td>
                            <td>
                                <div class="fw-bold text-white">@item.Negocio.Nombre</div>
                                <small class="text-info">/t/@item.Negocio.UrlPersonalizada</small>
                            </td>
                            <td class="text-light small">@item.Negocio.WhatsApp</td>
                            
                            <td>
                                <div class="small text-light">@(item.Usuario != null ? item.Usuario.Email : "Sin Usuario")</div>
                                <div class="font-monospace text-warning" style="font-size:0.8rem;">Clave: @(item.Usuario != null ? item.Usuario.Password : "-")</div>
                            </td>

                            <td class="text-center">
                                <span class="badge @(esActivo ? "badge-activo" : "badge-inactivo") px-2.5 py-1.5">
                                    ● @(esActivo ? "Activo" : "Pausado")
                                </span>
                            </td>
                            
                            <td class="text-center"><span class="badge bg-success bg-opacity-25 text-success px-3">@item.CantidadProductos</span></td>
                            <td class="text-end">
                                <form action="/KovakAdmin/AlternarEstado" method="post" class="d-inline">
                                    <input type="hidden" name="token" value="@ViewBag.Token" />
                                    <input type="hidden" name="id" value="@item.Negocio.ID" />
                                    <button type="submit" class="btn btn-sm @(esActivo ? "btn-outline-secondary" : "btn-success") me-1">
                                        @(esActivo ? "Pausar" : "Activar")
                                    </button>
                                </form>

                                <button type="button" class="btn btn-sm btn-outline-warning me-1" onclick="toggleEdit('@rowId')">Editar Acceso</button>
                                <a href="/t/@item.Negocio.UrlPersonalizada" target="_blank" class="btn btn-sm btn-outline-info me-1">Ver Web</a>
                                
                                <form action="/KovakAdmin/Eliminar" method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro de que querés eliminar por completo este comercio?');">
                                    <input type="hidden" name="token" value="@ViewBag.Token" />
                                    <input type="hidden" name="id" value="@item.Negocio.ID" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                </form>
                            </td>
                        </tr>

                        <tr id="@rowId" class="edit-row">
                            <td colspan="7" class="p-3 bg-dark bg-opacity-50">
                                <form action="/KovakAdmin/ModificarAcceso" method="post" class="row g-3 align-items-center">
                                    <input type="hidden" name="token" value="@ViewBag.Token" />
                                    <input type="hidden" name="negocioId" value="@item.Negocio.ID" />
                                    
                                    <div class="col-sm-4">
                                        <label class="small text-muted d-block mb-1">Nuevo Correo</label>
                                        <input type="email" name="nuevoEmail" class="form-control form-control-sm" value="@(item.Usuario != null ? item.Usuario.Email : "")" required />
                                    </div>
                                    <div class="col-sm-4">
                                        <label class="small text-muted d-block mb-1">Nueva Contraseña</label>
                                        <input type="text" name="nuevaPassword" class="form-control form-control-sm" value="@(item.Usuario != null ? item.Usuario.Password : "")" required />
                                    </div>
                                    <div class="col-sm-4 text-end pt-3">
                                        <button type="button" class="btn btn-sm btn-secondary me-2" onclick="toggleEdit('@rowId')">Cancelar</button>
                                        <button type="submit" class="btn btn-sm btn-success">Guardar Cambios</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script>
        function toggleEdit(id) {
            var row = document.getElementById(id);
            if (row.style.display === "table-row") {
                row.style.display = "none";
            } else {
                row.style.display = "table-row";
            }
        }
    </script>
</body>
</html>
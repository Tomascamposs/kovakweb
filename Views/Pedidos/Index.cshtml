@model IEnumerable<KovakWeb.Models.Pedido>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Pedidos - Kovak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background-color: #212529; color: white; padding-top: 20px; }
        .sidebar a { color: #adb5bd; text-decoration: none; padding: 12px 20px; display: block; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { color: white; background-color: #343a40; border-left: 4px solid #0d6efd; }
        .content { padding: 30px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            
            <div class="col-md-2 sidebar position-fixed">
                <h4 class="text-center mb-4 fw-bold">Kovak Admin</h4>
                <a href="/">📊 Dashboard</a>
                <a href="/Productos">📦 Productos</a>
                <a href="/Pedidos">🛒 Pedidos</a>
                <a href="/Configuracion">⚙️ Configuración</a>
            </div>

            <div class="col-md-10 offset-md-2 content">
                <h2 class="mb-4">Gestión de Pedidos</h2>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">ID Pedido</th>
                                    <th>Cliente</th>
                                    <th>Fecha</th>
                                    <th>Total</th>
                                    <th>Estado</th>
                                    <th class="text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            No ingresó ningún pedido todavía.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">#@item.ID</td>
                                            <td>@item.NombreCliente</td>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold text-success">$ @item.Total.ToString("N2")</td>
                                            <td>
                                                @if (item.Estado == "Pendiente") { <span class="badge bg-warning text-dark">Pendiente</span> }
                                                else if (item.Estado == "Completado") { <span class="badge bg-success">Completado</span> }
                                                else { <span class="badge bg-danger">Cancelado</span> }
                                            </td>
                                            <td class="text-end pe-4">
                                                <form asp-action="CambiarEstado" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@item.ID" />
                                                    <input type="hidden" name="nuevoEstado" value="Completado" />
                                                    <button type="submit" class="btn btn-sm btn-success me-1">✔️ Completar</button>
                                                </form>
                                                <form asp-action="CambiarEstado" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@item.ID" />
                                                    <input type="hidden" name="nuevoEstado" value="Cancelado" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">❌ Cancelar</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</body>
</html>
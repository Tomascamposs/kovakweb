@model KovakWeb.Models.Producto

@{ Layout = null; }

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Producto - Kovak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background-color: #212529; color: white; padding-top: 20px; }
        .sidebar a { color: #adb5bd; text-decoration: none; padding: 12px 20px; display: block; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { color: white; background-color: #343a40; border-left: 4px solid #0d6efd; }
        .content { padding: 30px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar position-fixed">
                <h4 class="text-center mb-4 fw-bold">Kovak Admin</h4>
                <a href="/">📊 Dashboard</a>
                <a href="/Productos" class="active">📦 Productos</a>
                <a href="/Categorias">📁 Categorías</a>
                <a href="/Pedidos">🛒 Pedidos</a>
                <a href="/Configuracion">⚙️ Configuración</a>
            </div>

            <div class="col-md-10 offset-md-2 content">
                <div class="mb-4">
                    <a href="/Productos" class="btn btn-sm btn-outline-secondary mb-3">← Volver al stock</a>
                    <h2>Editar Producto</h2>
                </div>

                <div class="card shadow-sm border-0" style="max-width: 650px;">
                    <div class="card-body p-4">
                        <form asp-action="Editar" method="post" enctype="multipart/form-data">
                            <input type="hidden" asp-for="ID" />
                            <input type="hidden" asp-for="NegocioID" />
                            <input type="hidden" asp-for="Activo" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Categoría *</label>
                                <select asp-for="CategoriaID" class="form-select" required>
                                    <option value="">Seleccioná una categoría...</option>
                                    @foreach(var cat in ViewBag.Categorias) {
                                        <option value="@cat.ID">@cat.Nombre</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Nombre del Producto *</label>
                                <input asp-for="Nombre" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Precio ($) *</label>
                                <input asp-for="Precio" type="number" step="0.01" class="form-control" required />
                            </div>

                            <div class="mb-4 p-3 bg-light rounded border">
                                <label class="form-label fw-bold d-block mb-2">Desglose de Stock por Talle *</label>
                                <div id="contenedorTalles">
                                    @if (ViewBag.TallesActuales != null && ((List<KovakWeb.Models.ProductoTalle>)ViewBag.TallesActuales).Any())
                                    {
                                        foreach (var talle in (List<KovakWeb.Models.ProductoTalle>)ViewBag.TallesActuales)
                                        {
                                            <div class="row g-2 mb-2 talle-row">
                                                <div class="col-6">
                                                    <input type="text" name="talles" class="form-control form-control-sm" value="@talle.Talle" required />
                                                </div>
                                                <div class="col-4">
                                                    <input type="number" name="cantidades" class="form-control form-control-sm" value="@talle.Cantidad" min="0" required />
                                                </div>
                                                <div class="col-2">
                                                    <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="eliminarFilaTalle(this)">✕</button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="row g-2 mb-2 talle-row">
                                            <div class="col-6">
                                                <input type="text" name="talles" class="form-control form-control-sm" placeholder="Ej: S, M, XL" required />
                                            </div>
                                            <div class="col-4">
                                                <input type="number" name="cantidades" class="form-control form-control-sm" value="0" min="0" required />
                                            </div>
                                            <div class="col-2">
                                                <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="eliminarFilaTalle(this)">✕</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <button type="button" class="btn btn-sm btn-dark mt-1" onclick="agregarFilaTalle()">+ Agregar variante de talle</button>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Descripción</label>
                                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                            </div>

                            <input type="hidden" asp-for="UrlImagen" />
                            <input type="hidden" asp-for="UrlImagen2" />
                            <input type="hidden" asp-for="UrlImagen3" />
                            <input type="hidden" asp-for="UrlImagen4" />

                            <div class="mb-4">
                                <h5 class="fw-bold border-bottom pb-2">Imágenes del Producto (Máx 4)</h5>
                                <div class="form-text mb-3">Solo seleccioná archivos si querés REEMPLAZAR las fotos actuales.</div>
                                
                                @for(int i = 1; i <= 4; i++) {
                                    var urlActual = i == 1 ? Model.UrlImagen : i == 2 ? Model.UrlImagen2 : i == 3 ? Model.UrlImagen3 : Model.UrlImagen4;
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <div style="width: 50px; height: 50px; background: #eee; border-radius:4px; overflow:hidden;">
                                            @if(!string.IsNullOrEmpty(urlActual)) { <img src="@urlActual" style="width:100%; height:100%; object-fit:cover;" /> }
                                            else { <span class="d-flex align-items-center justify-content-center h-100 small text-muted">-</span> }
                                        </div>
                                        <div class="flex-grow-1">
                                            <label class="small fw-bold mb-0">Foto @i @(i==1 ? "(Portada)" : "")</label>
                                            <input type="file" name="img@(i)" class="form-control form-control-sm" accept="image/*" />
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-success fw-bold py-2">Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function agregarFilaTalle() {
            const contenedor = document.getElementById('contenedorTalles');
            const nuevaFila = document.createElement('div');
            nuevaFila.className = 'row g-2 mb-2 talle-row';
            nuevaFila.innerHTML = `
                <div class="col-6">
                    <input type="text" name="talles" class="form-control form-control-sm" placeholder="Ej: S, M, XL" required />
                </div>
                <div class="col-4">
                    <input type="number" name="cantidades" class="form-control form-control-sm" value="0" min="0" required />
                </div>
                <div class="col-2">
                    <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="eliminarFilaTalle(this)">✕</button>
                </div>`;
            contenedor.appendChild(nuevaFila);
        }

        function eliminarFilaTalle(btn) {
            const filas = document.querySelectorAll('.talle-row');
            if(filas.length > 1) {
                btn.closest('.talle-row').remove();
            } else {
                alert('El producto debe tener al menos un talle especificado.');
            }
        }
    </script>
</body>
</html>
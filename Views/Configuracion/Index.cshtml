@model KovakWeb.Models.Negocio
@{ Layout = null; }

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Configuración - Kovak</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background-color: #212529; color: white; padding-top: 20px; }
        .sidebar a { color: #adb5bd; text-decoration: none; padding: 12px 20px; display: block; font-weight: 500; }
        .sidebar a:hover, .sidebar a.active { color: white; background-color: #343a40; border-left: 4px solid #0d6efd; }
        .content { padding: 30px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            
            <div class="col-md-2 sidebar position-fixed">
                <h4 class="text-center mb-4 fw-bold">Kovak Admin</h4>
                <a href="/">📊 Dashboard</a>
                <a href="/Productos">📦 Productos</a>
                <a href="/Pedidos">🛒 Pedidos</a>
                <a href="/Configuracion" class="active">⚙️ Configuración</a>
            </div>

            <div class="col-md-10 offset-md-2 content">
                <h2 class="mb-4">Datos del Negocio</h2>

                @if (TempData["MensajeExito"] != null)
                {
                    <div class="alert alert-success fw-bold">@TempData["MensajeExito"]</div>
                }

                <div class="card shadow-sm border-0" style="max-width: 600px;">
                    <div class="card-body p-4">
                        <form asp-action="Guardar" method="post">
                            <input type="hidden" asp-for="ID" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Nombre Comercial</label>
                                <input asp-for="Nombre" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Número de WhatsApp (Sin el +)</label>
                                <input asp-for="WhatsApp" class="form-control" placeholder="Ej: 5493815555555" required />
                                <div class="form-text">Este es el número al que llegarán los pedidos desde la web.</div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">URL Personalizada</label>
                                <input asp-for="UrlPersonalizada" class="form-control" placeholder="Ej: mi-negocio" required />
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-dark fw-bold py-2">Guardar Configuración</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>